# Copia este archivo a ".env.local" y personaliza los valores.
# .env.local no se sube a git (está en .gitignore).

# --- Sitio ---
NEXT_PUBLIC_SITE_NAME=Somos la Voz Templo Central
NEXT_PUBLIC_SITE_DESCRIPTION=Iglesia Somos la Voz — Templo Central. Cultos, comunidad y esperanza.
NEXT_PUBLIC_SITE_TAGLINE=Un lugar donde la fe cobra vida, la comunidad se construye y todos son bienvenidos.

# Dirección (una sola línea)
NEXT_PUBLIC_SITE_ADDRESS=Tacora 2573, Independencia, Santiago, Chile

# URLs directas a mapas (opcional; si están vacías se generan desde SITE_ADDRESS)
# NEXT_PUBLIC_MAPS_GOOGLE_URL=https://maps.google.com/?q=...
# NEXT_PUBLIC_MAPS_WAZE_URL=https://waze.com/ul?ll=-33.45,-70.66&navigate=yes

# Contacto (deja vacío para ocultar la fila en el footer)
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# Pastores (mensaje de bienvenida)
NEXT_PUBLIC_PASTORS_NAMES=Felix Fuentes y Maria Ester Bravo
NEXT_PUBLIC_PASTORS_TITLE=Pastores principales

# Ofrendas Flow
NEXT_PUBLIC_DONATE_FLOW_URL=https://www.flow.cl/app/web/pagarBtnPago.php?token=eohyyvl

# App móvil
NEXT_PUBLIC_APPLE_STORE_URL=https://apps.apple.com/cl/app/somos-la-voz/id6593660269
NEXT_PUBLIC_GOOGLE_PLAY_URL=

# Correo para formularios (backend/server-only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PRAYER_REQUEST_TO_EMAIL=
# Opcional: remitente visible (si no, usa SMTP_USER)
# PRAYER_FROM_EMAIL=

# Redes — URL completa recomendada. También puedes usar solo:
#   Instagram: usuario (ej. miiglesia)
#   YouTube: @NombreCanal o usuario
#   X: usuario sin @
#   Spotify: enlace open.spotify.com/... desde “Compartir”, o solo el id de usuario (ej. somoslavozdg → …/user/somoslavozdg)
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://www.facebook.com/TemploCentral
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/veed_templocentral/
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://www.youtube.com/@TemploCentralOficial
NEXT_PUBLIC_SOCIAL_X_URL=
NEXT_PUBLIC_SOCIAL_SPOTIFY_URL=

# Programa de radio (banner Chile para Cristo): URL completa del streaming o podcast
NEXT_PUBLIC_RADIO_LISTEN_URL=

# Mensajes recientes (home): mismo orden que las tarjetas (1 = izquierda … 3 = derecha)
# Textos (opcional; si omites, se usan los valores por defecto del sitio)
# NEXT_PUBLIC_RECENT_MESSAGE_1_TITLE=
# NEXT_PUBLIC_RECENT_MESSAGE_1_SPEAKER=
# NEXT_PUBLIC_RECENT_MESSAGE_1_DATE=
# NEXT_PUBLIC_RECENT_MESSAGE_1_DURATION=
# NEXT_PUBLIC_RECENT_MESSAGE_2_TITLE=
# NEXT_PUBLIC_RECENT_MESSAGE_2_SPEAKER=
# NEXT_PUBLIC_RECENT_MESSAGE_2_DATE=
# NEXT_PUBLIC_RECENT_MESSAGE_2_DURATION=
# NEXT_PUBLIC_RECENT_MESSAGE_3_TITLE=
# NEXT_PUBLIC_RECENT_MESSAGE_3_SPEAKER=
# NEXT_PUBLIC_RECENT_MESSAGE_3_DATE=
# NEXT_PUBLIC_RECENT_MESSAGE_3_DURATION=
# Miniaturas bajo /public (opcional; ej. /images/predica-1.png)
# NEXT_PUBLIC_RECENT_MESSAGE_1_IMAGE=
# NEXT_PUBLIC_RECENT_MESSAGE_2_IMAGE=
# NEXT_PUBLIC_RECENT_MESSAGE_3_IMAGE=
# Videos YouTube (opcional; vacío = miniatura sin enlace)
# NEXT_PUBLIC_RECENT_MESSAGE_VIDEO_1_URL=https://www.youtube.com/watch?v=...
# NEXT_PUBLIC_RECENT_MESSAGE_VIDEO_2_URL=
# NEXT_PUBLIC_RECENT_MESSAGE_VIDEO_3_URL=
